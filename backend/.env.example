# ============================================================================
# WhatsyITC backend — environment template
# Copy this file to `.env` and fill in the real values. NEVER commit `.env`.
# Generate a JWT secret with:    openssl rand -base64 48
# Generate an admin password with: openssl rand -base64 18
# ============================================================================

# --- Runtime ---
# PORT is the HTTP listen port for the Go server.
PORT=8082

# ENV controls log format + cookie Secure flag + dev-only routes.
# Allowed: development | production
ENV=production

# Allowed CORS origin(s). For multiple origins (e.g. staging + prod) use a
# comma-separated list in FRONTEND_URLS — that takes precedence over
# FRONTEND_URL.
FRONTEND_URL=https://admin.your-domain.com
# FRONTEND_URLS=https://admin.your-domain.com,https://staging.your-domain.com

# --- Database (Postgres / Supabase / RDS / etc.) ---
# Connection string with credentials. Use sslmode=require for managed DBs.
POSTGRES_URI=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# --- Auth ---
# HS256 signing key. MUST be at least 32 bytes — the server refuses to boot
# with anything shorter. Rotate this to invalidate every active session.
BC_JWT_SECRET=replace-me-with-openssl-rand-base64-48

# Optional "aud" claim asserted on every request. Empty disables the check.
BC_JWT_AUDIENCE=whatsyitc-admin

# bcrypt cost for newly-hashed passwords. 10–12 is sensible. Existing hashes
# keep their original cost; this only affects new passwords (e.g. the seed).
BC_BCRYPT_COST=12

# In-memory job queue worker pool size. Increase to process more sends in
# parallel (capped by Meta's per-second rate limit on your phone number).
BC_WORKER_CONCURRENCY=4

# --- Login throttling ---
# Per-IP token bucket on POST /auth/login. Lower = stricter.
BC_LOGIN_RPS=1
BC_LOGIN_BURST=5

# --- Uploads ---
# Where batch .xlsx files land after multipart upload. Server creates it if
# it doesn't exist; must be writable by the server user.
BC_UPLOAD_DIR=./uploads

# Cap for multipart upload size in bytes (default 25 MB).
BC_MAX_UPLOAD_BYTES=26214400

# Cap for JSON request bodies in bytes (default 1 MB). Defends all /api
# endpoints against oversize POSTs.
BC_MAX_JSON_BYTES=1048576

# --- AI / LLM providers ---
# Option A (recommended for Amazon Bedrock API keys): set a Bedrock bearer
# token plus the AWS region and one model id. The server uses Bedrock Converse.
AWS_REGION=ap-south-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# Option B (custom OpenAI-compatible Bedrock gateway): set the gateway base
# URL ending in /v1 plus the same token and model. When BEDROCK_BASE_URL is
# present, the server uses the OpenAI Chat Completions SDK against this URL.
# BEDROCK_BASE_URL=https://your-bedrock-gateway.example.com/v1
# BEDROCK_API_KEY=
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# Optional OpenAI fallback / embeddings. OPENAI_BASE_URL lets you point the
# OpenAI SDK at any OpenAI-compatible API for normal OpenAI calls.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4.1
# OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Meta WhatsApp Cloud API ---
# Each admin now uploads their own WABA credentials in Settings (see the
# /admin/settings page). The server no longer reads WHATS_PHONE_NUMBER_ID /
# WHATS_ACCESS_TOKEN / WHATS_VERIFY_TOKEN from env. The single remaining
# env var is the default Meta Graph API version, used when an admin has
# not overridden it on their settings row.
WHATS_API_VERSION=v25.0

# --- Field encryption (per-user secrets at rest) ---
# 32-byte AES-256 key used to encrypt each admin's WhatsApp access_token
# and verify_token before they land in bc_whatsapp_credentials. Generate
# with: openssl rand -base64 48 | head -c 32
#
# Rotation: changing this key INVALIDATES every existing credentials
# row (their ciphertexts can no longer be decrypted, so every admin
# must re-enter their token in Settings). Plan a maintenance window.
BC_FIELD_ENC_KEY=replace-me-with-32-random-bytes

# --- Internal ---
# Directory of *.sql migration files. Default is fine for normal runs.
# BC_MIGRATIONS_DIR=internal/db/migrations
# --- Google OAuth (optional) ---
# When all three of these are filled in, the /login page renders an
# enabled "Continue with Google" button. Leave BC_GOOGLE_CLIENT_ID empty
# to disable — the button will render in a disabled state with a tooltip
# instead of failing.
#
# Create the OAuth client at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized redirect URI: BC_GOOGLE_REDIRECT_URL
#   - Scopes: openid, email, profile

# Default (works for local dev): http://localhost:8082/auth/google/callback
# For production, set this to your public backend URL.
# Default for local dev (Vite proxies /auth/* to the Go backend on :8082):
#   http://localhost:5173/auth/google/callback
# For production, set this to your public frontend origin so the
# post-callback redirect lands on the React app (which reads any
# google_error=... query string and renders /login):
#   https://admin.your-domain.com/auth/google/callback
BC_GOOGLE_REDIRECT_URL=
